# Copier ce fichier en .env et remplir les valeurs

# PostgreSQL — adapter selon votre config locale
# Linux exemple  : postgresql://hyo:motdepasse@localhost:5433/gmp?schema=public
# Windows exemple: postgresql://postgres:motdepasse@localhost:5432/gmp?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gmp?schema=public"

# Auth.js — générer avec : npx auth secret
AUTH_SECRET=""

# Resend — créer un compte sur resend.com et générer une clé API
RESEND_API_KEY=""

# Email expéditeur (doit être un domaine vérifié sur Resend)
RESEND_FROM="noreply@votre-domaine.fr"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ETUDIANT
  ENSEIGNANT
  ENTREPRISE
  ADMIN
}

enum Parcours {
  SIMULATION_REALITE_VIRTUELLE
  CONCEPTION_PRODUCTION_DURABLE
  NON_DEFINI
  LP_MIE
  LP_MIEF
  LP_MRI
}

enum TypeFormation {
  INITIALE
  ALTERNANCE
}

enum TypeGroupe {
  CM
  TD
  TP
}

enum Statut {
  PENDING
  PUBLISHED
  REJECTED
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  password         String
  nom              String
  prenom           String
  role             Role
  actif            Boolean       @default(true)
  parcours         Parcours      @default(NON_DEFINI)
  typeFormation    TypeFormation @default(INITIALE)
  anneePromotion   Int           @default(1)
  promesseEmbauche Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  notesRecues      Note[]            @relation("NotesEtudiant")
  notesDeposees    Note[]            @relation("NotesEnseignant")
  emploisDuTemps   EmploiDuTemps[]
  supports         SupportDeCours[]
  projets          ProjetTuteure[]
  offres           OffreAlternance[]
  groupes          Groupe[]          @relation("GroupeEtudiants")
  resetTokens      ResetToken[]
  matieres         MatiereEnseignant[]
}

model ResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model Groupe {
  id            String     @id @default(cuid())
  nom           String
  type          TypeGroupe
  anneeScolaire String

  etudiants  User[]          @relation("GroupeEtudiants")
  creneaux   EmploiDuTemps[]
}

model UE {
  id          String    @id @default(cuid())
  nom         String
  code        String    @unique
  coefficient Float

  matieres    Matiere[]
}

model Matiere {
  id   String @id @default(cuid())
  nom  String
  code String @unique

  ue    UE     @relation(fields: [ueId], references: [id])
  ueId  String

  notes            Note[]
  enseignants      MatiereEnseignant[]
  emploisDuTemps   EmploiDuTemps[]
}

model MatiereEnseignant {
  enseignant   User    @relation(fields: [enseignantId], references: [id])
  enseignantId String
  matiere      Matiere @relation(fields: [matiereId], references: [id])
  matiereId    String

  @@id([enseignantId, matiereId])
}

model Note {
  id        String   @id @default(cuid())
  valeur    Float
  semestre  Int
  annee     Int
  dateDepot DateTime @default(now())

  etudiant     User    @relation("NotesEtudiant", fields: [etudiantId], references: [id])
  etudiantId   String

  enseignant   User    @relation("NotesEnseignant", fields: [enseignantId], references: [id])
  enseignantId String

  matiere   Matiere @relation(fields: [matiereId], references: [id])
  matiereId String
}

model EmploiDuTemps {
  id            String    @id @default(cuid())
  semaine       DateTime
  jour          String
  heureDebut    String
  heureFin      String
  salle         String
  intitule      String
  recurrent     Boolean   @default(false)
  recurrenceFin DateTime?

  groupe       Groupe  @relation(fields: [groupeId], references: [id])
  groupeId     String

  enseignant   User    @relation(fields: [enseignantId], references: [id])
  enseignantId String

  matiere      Matiere? @relation(fields: [matiereId], references: [id])
  matiereId    String?
}

model SupportDeCours {
  id            String   @id @default(cuid())
  titre         String
  cheminFichier String
  taille        Int
  dateDepot     DateTime @default(now())

  enseignant   User   @relation(fields: [enseignantId], references: [id])
  enseignantId String
}

model ProjetTuteure {
  id          String   @id @default(cuid())
  titre       String
  description String
  prerequis   String?
  nbEtudiants Int      @default(1)
  statut      Statut   @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entreprise   User   @relation(fields: [entrepriseId], references: [id])
  entrepriseId String
}

model OffreAlternance {
  id           String   @id @default(cuid())
  poste        String
  description  String
  duree        String
  remuneration String?
  prerequis    String?
  statut       Statut   @default(PENDING)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entreprise   User   @relation(fields: [entrepriseId], references: [id])
  entrepriseId String
}
